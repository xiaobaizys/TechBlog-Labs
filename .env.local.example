# ================================
# 数据库 (PostgreSQL / Supabase)
# ================================
# Supabase 连接字符串格式:
# postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# 或者使用直连模式:
# postgresql://postgres.<project-ref>:<db-password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL="postgresql://root:root123@localhost:5432/techblog_labs?schema=public"

# 直连 URL（用于 Prisma 迁移，Supabase 需要）
DIRECT_URL="postgresql://root:root123@localhost:5432/techblog_labs?schema=public"

# ================================
# NextAuth (Auth.js v5)
# ================================
# 生成方式: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ================================
# GitHub OAuth（可选）
# ================================
# 在 https://github.com/settings/developers 创建 OAuth App
# GITHUB_CLIENT_ID="your-github-client-id"
# GITHUB_CLIENT_SECRET="your-github-client-secret"

# ================================
# DeepSeek AI
# ================================
# 在 https://platform.deepseek.com 获取 API Key
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"

# ================================
# OpenAI (可选，作为备选 AI Provider)
# ================================
# OPENAI_API_KEY="sk-your-openai-api-key"
